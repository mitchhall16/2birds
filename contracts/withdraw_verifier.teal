#pragma version 11
// Groth16 Verifier Application for Algorand AVM
// nPublic: 6
// Generated from verification key

// === Budget padding: approve immediately if no args (inner call) ===
txn NumAppArgs
pushint 0
==
bnz budget_pad_approve

// === Step 1: Extract proof from arg[0] (256 bytes) ===
txna ApplicationArgs 0
len
pushint 256
==
assert // proof must be 256 bytes

// pi_a = arg[0][0:64] (G1 point)
txna ApplicationArgs 0
extract 0 64
store 0 // pi_a

// pi_b = arg[0][64:192] (G2 point)
txna ApplicationArgs 0
extract 64 128
store 1 // pi_b

// pi_c = arg[0][192:256] (G1 point)
txna ApplicationArgs 0
extract 192 64
store 2 // pi_c

// === Step 2: Extract 6 public signals from arg[1] (192 bytes) ===
txna ApplicationArgs 1
len
pushint 192
==
assert // public signals must be nPublic * 32 bytes

// === Step 3: Pad opcode budget via inner calls to budget helper ===
budget_pad_loop:
global OpcodeBudget
pushint 148000
>
bnz budget_pad_done
itxn_begin
pushint 6 // appl
itxn_field TypeEnum
txna Applications 1 // budget helper app from foreign apps
itxn_field ApplicationID
pushint 0
itxn_field Fee
itxn_submit
b budget_pad_loop
budget_pad_done:

// === Step 4: Compute vk_x = IC[0] + sum(signals[i] * IC[i+1]) ===

// vk_x = IC[0]
pushbytes 0x10bc40e1e4c31d8632323a14c55ddc20a8d0e6eab85d5ce54530dda8a7daeaf310d97e31b5767907b06eed7c8c759fac370b7717d8e20e4539891a3e37358b7a
store 10 // vk_x = IC[0]

// vk_x += signal[0] * IC[1]
pushbytes 0x191e22243016b795a4e5a386e7580d29036b09ae739ff2d755f1acd538d4217929b30dee069ce71fcfcb3d1940a38ee6e443a6776737ffed8dcd88d30d8e8025
txna ApplicationArgs 1
extract 0 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// vk_x += signal[1] * IC[2]
pushbytes 0x1c015031bf570a4b8e286bcc2c9d23f96135bcad13b094b011665d4985d465861b89b81feff4a20c6e85b5d085ac29b084c51b4b76d2b0866ca62a662daa60c8
txna ApplicationArgs 1
extract 32 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// vk_x += signal[2] * IC[3]
pushbytes 0x196e1c6fd0c81ba2de21b9ed01d83dc342767d3972841b228b78227d5153bb6b23c1c1ecf4b2839a9b970d4ab3860e54145f6824557528d9cefdb037c882ab6c
txna ApplicationArgs 1
extract 64 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// vk_x += signal[3] * IC[4]
pushbytes 0x02693549ac7a483bb9bd68343c260c2cd8fe1b231cea5368a61610caef83910b11e9d393b12826ed256d0373c2fa470b4a19ab6b0064420cc0037b0d9c0f31e6
txna ApplicationArgs 1
extract 96 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// vk_x += signal[4] * IC[5]
pushbytes 0x1d5ebb6f1be6ebc4462d0ff034fb82a92a99d50cc2a34f89c0b799875b48c1d111a6b106b3730aa544246a5b5867aec3372b17181ba52127262f0b0368684001
txna ApplicationArgs 1
extract 128 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// vk_x += signal[5] * IC[6]
pushbytes 0x0e57cbf67fdd20cdc5b263cbafca251dad3460d4d38dd9ba793229c26582be381e90a8996ede72f27e448abba49ab47d57fa4617d9c3309fafe1130b835663cb
txna ApplicationArgs 1
extract 160 32
ec_scalar_mul BN254g1
load 10
swap
ec_add BN254g1
store 10 // vk_x updated

// === Step 5: Negate pi_a (flip y coordinate) ===
load 0 // pi_a
extract 0 32 // A.x
load 0 // pi_a
extract 32 32 // A.y
pushbytes 0x30644e72e131a029b85045b68181585d97816a916871ca8d3c208c16d87cfd47 // field prime
swap
b- // field_prime - A.y
dup
len
pushint 32
swap
-
bzero
swap
concat // left-pad to 32 bytes
// Stack: A.x, neg_A.y
concat // -A = A.x || neg_A.y
store 3 // -pi_a (negated)

// === Step 6: Pairing check ===
// G1 array: -A || alpha || vk_x || C
load 3 // -A
pushbytes 0x2d4d9aa7e302d9df41749d5507949d05dbea33fbb16c643b22f599a2be6df2e214bedd503c37ceb061d8ec60209fe345ce89830a19230301f076caff004d1926 // alpha
concat
load 10 // vk_x
concat
load 2 // C
concat

// G2 array: B || beta || gamma || delta
load 1 // B
pushbytes 0x0e187847ad4c798374d0d6732bf501847dd68bc0e071241e0213bc7fc13db7ab0967032fcbf776d1afc985f88877f182d38480a653f2decaa9794cbc3bf3060c1739c1b1a457a8c7313123d24d2f9192f896b7c63eea05a9d57f06547ad0cec8304cfbd1e08a704a99f5e847d93f8c3caafddec46b7a0d379da69a4d112346a7 // beta
concat
pushbytes 0x1800deef121f1e76426a00665e5c4479674322d4f75edadd46debd5cd992f6ed198e9393920d483a7260bfb731fb5d25f1aa493335a9e71297e485b7aef312c212c85ea5db8c6deb4aab71808dcb408fe3d1e7690c43d37b4ce6cc0166fa7daa090689d0585ff075ec9e99ad690c3395bc4b313370b38ef355acdadcd122975b // gamma
concat
pushbytes 0x00870c962e79bcb50f6191aa67243629aca149ec4be9944b74054b5b24d35ad82d78ba2b6e96cba1a4f74cfe67a82b0711cce62a15f9cc570f7ecafb6b27eca71e1f0765d7556a1af1656649eb82177f21c9adf3b61e756eb0fe71e6ae16c5750f2f7a532ce57ad035f0085f1a4dcc22d01e10dc301e7fbc6b49ee8a83af5643 // delta
concat

// Verify: e(-A,B) * e(alpha,beta) * e(vk_x,gamma) * e(C,delta) == 1
ec_pairing_check BN254g1
assert // pairing check must pass

pushint 1 // approve
return

// Budget padding entry point — approve immediately
budget_pad_approve:
pushint 1
return